    <title>设计模式之组合模式</title>
    <link href="https://github-blog.victorchu.info/posts/34ace952/"/>
    <id>https://github-blog.victorchu.info/posts/34ace952/</id>
    <published>2017-01-16T16:59:51.000Z</published>
